{
  "manifest_version": 3,
  "name": "RouteTracker",
  "version": "0.1.0",
  "description": "RouteTracker right-side transparent overlay for every page.",
  "action": {
    "default_title": "RouteTracker",
    "default_popup": "src/popup/popup.html"
  },
  "permissions": ["storage", "webRequest", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/overlay/index.js",
        "src/overlay/dom.js",
        "src/network-interceptor.js",
        "src/injected-script.js",
        "src/shared/storage.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["src/overlay/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Toggle right-side panel"
    }
  }
}
